# ─── ALIP backend environment ─────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit .env. Keys stay server-side only.

# App
ALIP_ENV=development
ALIP_LOG_LEVEL=INFO
ALIP_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# LLM analyst (OpenAI-compatible — NEVER exposed to the browser).
# Works with any OpenAI-compatible endpoint. Pick a FREE provider:
#
#   Groq (free, fast, no billing) — https://console.groq.com/keys
#     OPENAI_BASE_URL=https://api.groq.com/openai/v1/chat/completions
#     OPENAI_MODEL=llama-3.3-70b-versatile   (fallback: llama-3.1-8b-instant)
#   Google Gemini (free tier) — https://aistudio.google.com/apikey
#     OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#     OPENAI_MODEL=gemini-2.0-flash
#   Ollama (fully local, no key) — install from ollama.com, `ollama pull llama3.2`
#     OPENAI_BASE_URL=http://localhost:11434/v1/chat/completions
#     OPENAI_MODEL=llama3.2   (no OPENAI_API_KEY needed)
#   OpenAI (paid) — https://api.openai.com/v1/chat/completions , gpt-4o-mini
#
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1/chat/completions
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_FALLBACK_MODEL=llama-3.1-8b-instant
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRIES=3

# Tavily (company research — NEVER exposed to the browser)
TAVILY_API_KEY=
TAVILY_TIMEOUT=20
TAVILY_MAX_RETRIES=3

# Research cache
RESEARCH_CACHE_TTL_DAYS=7

# Persistence (optional — falls back to in-memory store if unset)
# DATABASE_URL = your Supabase Postgres connection string:
#   Supabase → Project Settings → Database → Connection string → URI
#   e.g. postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Local dev/tests can use SQLite: sqlite:///./alip.db
DATABASE_URL=

# supabase-py client (optional — for auth/storage later; not required for persistence)
SUPABASE_URL=
SUPABASE_KEY=
